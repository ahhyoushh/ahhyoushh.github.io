---
import Base from './Base.astro';

export interface Props {
  title: string;
}
const { title } = Astro.props;
---
<Base title={title}>
  <Fragment slot="nav">
    <nav>
      <div class="nav-brand"><a href="/">$ ayush</a></div>
      <a href="/blogs" class="nav-back">← blogs</a>
    </nav>
  </Fragment>

  <section class="md-content">
    <slot />
  </section>
</Base>
